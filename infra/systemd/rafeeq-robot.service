[Unit]
Description=RAFEEQ Robot Service
After=network-online.target

[Service]
Type=simple
User=rafeeq
WorkingDirectory=/opt/rafeeq
EnvironmentFile=/etc/rafeeq/robot.env
ExecStart=/opt/rafeeq/edge/robot/.venv/bin/rafeeq-robot --daemon
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
