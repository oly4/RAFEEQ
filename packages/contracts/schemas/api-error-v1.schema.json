{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["error"],
  "properties": {
    "error": {
      "type": "object",
      "required": ["code", "message", "details", "request_id"],
      "properties": {
        "code": {"type": "string"}, "message": {"type": "string"},
        "details": {"type": "object"}, "request_id": {"type": "string", "format": "uuid"}
      }
    }
  }
}

